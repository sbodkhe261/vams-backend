generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Companies table to store tenants
model Company {
  id              String           @id @default(uuid())
  name            String           @unique
  isActive        Boolean          @default(true)
  tier            String           @default("BASIC")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  alerts          Alert[]
  alertRules      AlertRule[]
  settings        CompanySettings?
  defects         DefectMaster[]
  escalationRules EscalationRule[]
  notifications   Notification[]
  users           User[]

  @@map("companies")
}

/// Tenant configuration (e.g. customized sound maps, notification routing overrides)
model CompanySettings {
  id                 String   @id @default(uuid())
  companyId          String   @unique
  soundInfo          String   @default("soft_bell.wav")
  soundWarning       String   @default("chime.wav")
  soundCritical      String   @default("alarm.wav")
  soundEmergency     String   @default("siren.wav")
  maxUsers           Int      @default(0)
  allowedRoles       String[] @default([])
  whatsappEnabled    Boolean  @default(false)
  whatsappApiKey     String?
  whatsappSenderNum  String?
  escalationGraceMin Int      @default(1440)
  rulebook           Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

/// Users table with multi-tenant company association and RBAC Roles
model User {
  id                String                     @id @default(uuid())
  email             String
  passwordHash      String
  name              String
  role              UserRole
  companyId         String
  isActive          Boolean                    @default(true)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  fcmToken          String?
  actionedHistories AlertAssignmentHistory[]   @relation("AssignedByUser")
  assignedHistories AlertAssignmentHistory[]   @relation("AssignedToUser")
  assignedAlerts    Alert[]                    @relation("AssignedUser")
  createdAlerts     Alert[]                    @relation("CreatedByUser")
  timelineEvents    DefectResolutionTimeline[]
  preferences       NotificationPreference[]
  notifications     Notification[]
  comments          ResolutionComment[]
  resolutions       Resolution[]
  activityLogs      UserActivityLog[]
  company           Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
  @@index([companyId])
  @@index([role])
  @@map("users")
}

/// Audit trail of user activities
model UserActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("user_activity_logs")
}

/// Defect Master listing types of defects
model DefectMaster {
  id                  String   @id @default(uuid())
  name                String
  category            String
  severity            Severity
  defaultAssigneeRole UserRole @default(WORKER)
  ownerVisible        Boolean  @default(true)
  soundProfile        String   @default("INFO")
  active              Boolean  @default(true)
  companyId           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  alerts              Alert[]
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, active])
  @@map("defect_masters")
}

/// Alert Rules engine table
model AlertRule {
  id            String                @id @default(uuid())
  companyId     String
  severity      Severity
  rolesToNotify UserRole[]
  channels      NotificationChannel[]
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, severity])
  @@index([companyId])
  @@map("company_alert_rules")
}

/// Automatic Escalation Engine config
model EscalationRule {
  id                String   @id @default(uuid())
  companyId         String
  severity          Severity
  escalateAfterDays Int
  escalateToRole    UserRole
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, severity, escalateAfterDays])
  @@index([companyId])
  @@map("escalation_rules")
}

/// Live alerts generated by inspection/fleet systems
model Alert {
  id                   String                     @id @default(uuid())
  vin                  String?
  companyId            String
  defectId             String?
  defectName           String?
  alertDefinitionId    String?
  severity             Severity
  status               AlertStatus                @default(OPEN)
  assignedToUserId     String?
  assignedToRole       UserRole?
  assignedToDepartment String?
  assignedToTeam       String?
  createdById          String?
  isManual             Boolean                    @default(true)
  lastReminderSentAt   DateTime?
  escalationStep       Int                        @default(0)
  nextEscalationAt     DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  assignments          AlertAssignmentHistory[]
  assignedToUser       User?                      @relation("AssignedUser", fields: [assignedToUserId], references: [id])
  company              Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy            User?                      @relation("CreatedByUser", fields: [createdById], references: [id])
  defect               DefectMaster?              @relation(fields: [defectId], references: [id])
  timeline             DefectResolutionTimeline[]
  escalations          EscalationHistory[]
  notifications        Notification[]
  comments             ResolutionComment[]
  resolution           Resolution?

  @@index([companyId])
  @@index([status])
  @@index([severity])
  @@index([assignedToUserId])
  @@index([assignedToRole])
  @@index([nextEscalationAt])
  @@index([companyId, status])
  @@map("alerts")
}

/// Tracks assignment changes
model AlertAssignmentHistory {
  id                   String    @id @default(uuid())
  alertId              String
  assignedByUserId     String
  assignedToUserId     String?
  assignedToRole       UserRole?
  assignedToDepartment String?
  assignedToTeam       String?
  notes                String?
  assignedAt           DateTime  @default(now())
  alert                Alert     @relation(fields: [alertId], references: [id], onDelete: Cascade)
  assignedByUser       User      @relation("AssignedByUser", fields: [assignedByUserId], references: [id])
  assignedToUser       User?     @relation("AssignedToUser", fields: [assignedToUserId], references: [id])

  @@index([alertId])
  @@index([assignedAt])
  @@map("alert_assignment_histories")
}

/// Tracks automatic escalations triggered by the engine
model EscalationHistory {
  id              String    @id @default(uuid())
  alertId         String
  steppedFromRole UserRole?
  steppedToRole   UserRole
  steppedToUserId String?
  escalatedAt     DateTime  @default(now())
  notes           String?
  alert           Alert     @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@map("escalation_histories")
}

/// Full Audit Trail Timeline for defect lifecycle
model DefectResolutionTimeline {
  id                String    @id @default(uuid())
  alertId           String
  actionType        String
  performedByUserId String?
  performedByRole   UserRole?
  details           String
  createdAt         DateTime  @default(now())
  alert             Alert     @relation(fields: [alertId], references: [id], onDelete: Cascade)
  performedByUser   User?     @relation(fields: [performedByUserId], references: [id])

  @@index([alertId])
  @@index([createdAt])
  @@map("defect_resolution_timeline")
}

/// Stores resolution details (1-to-1 with Alert)
model Resolution {
  id               String   @id @default(uuid())
  alertId          String   @unique
  resolvedByUserId String
  resolvedAt       DateTime @default(now())
  reason           String
  notes            String?
  audioPath        String?
  transcription    String?
  imageUrls        String[]
  createdAt        DateTime @default(now())
  alert            Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  resolvedByUser   User     @relation(fields: [resolvedByUserId], references: [id])

  @@index([resolvedByUserId])
  @@map("resolutions")
}

/// Comments/notes added to the alert
model ResolutionComment {
  id            String   @id @default(uuid())
  alertId       String
  userId        String
  commentText   String
  audioPath     String?
  transcription String?
  createdAt     DateTime @default(now())
  alert         Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([alertId])
  @@map("resolution_comments")
}

/// Centralized notification history table
model Notification {
  id        String              @id @default(uuid())
  companyId String
  userId    String
  alertId   String?
  title     String
  message   String
  channel   NotificationChannel
  isRead    Boolean             @default(false)
  readAt    DateTime?
  createdAt DateTime            @default(now())
  alert     Alert?              @relation(fields: [alertId], references: [id])
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId, isRead])
  @@map("notifications")
}

/// User's channel preferences
model NotificationPreference {
  id        String              @id @default(uuid())
  userId    String
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_preferences")
}

/// System Roles supporting RBAC
enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  FACTORY_MANAGER
  SUPERVISOR
  WORKER
  QUALITY_INSPECTOR
  SERVICE_ENGINEER
  DEALER
  VEHICLE_OWNER
  READ_ONLY_USER
}

/// Alert Severity levels
enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
  EMERGENCY
}

/// Alert Lifecycle statuses
enum AlertStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REOPENED
}

/// Channels for message delivery
enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
  SMS
}

model AlertDefinition {
  id                String   @id @default(uuid())
  companyId         String
  alertId           String   @default("")
  name              String
  definition        String?
  type              String
  severity          Severity
  primaryAssigneeId String
  escalationChain   String[] // user IDs
  escalationTimeout Int      // in minutes
  criticalOverride  Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("alert_definitions")
}

model AlertAssignment {
  id              String    @id @default(uuid())
  alertId         String
  severity        Severity
  assignedToId    String
  assignedAt      DateTime  @default(now())
  notifiedAt      DateTime  @default(now())
  seenAt          DateTime?
  reminderCount   Int       @default(0)
  escalationLevel Int       @default(0)
  status          String    @default("OPEN") // "OPEN", "RESOLVED", "ESCALATED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([alertId])
  @@index([assignedToId])
  @@index([status])
  @@index([alertId, assignedToId, status])
  @@map("alert_assignments")
}

model AlertNotificationLog {
  id        String   @id @default(uuid())
  alertId   String
  userId    String
  type      String   // "NOTIFICATION", "REMINDER", "ESCALATION", "BROADCAST"
  message   String
  createdAt DateTime @default(now())

  @@index([alertId])
  @@index([userId])
  @@map("alert_notification_logs")
}

model CompanyBroadcastLog {
  id        String   @id @default(uuid())
  companyId String
  title     String
  message   String
  sentById  String
  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("company_broadcast_logs")
}
